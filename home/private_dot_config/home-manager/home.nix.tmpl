{ config, pkgs, lib, ... }:

{
  nixpkgs.config.allowUnfree = true;
  
  imports = [
    ./fish
    ./neovim
    ./podman
    ./tmux.nix
    ./vscode
  ];

  home.username = "{{ .chezmoi.username }}";
  home.homeDirectory = "{{ .chezmoi.homeDir }}";

  home.packages = with pkgs; [
    atuin
    bat
    bat-extras.batgrep
    bat-extras.batman
    delta
    dust
    eza
    fd
    ffmpeg_6
    fzf
    gcc
    git
    graphviz
    keychain
    procs
    reef
    ripgrep
    rustup
    shellcheck
    sourceHighlight
    starship
    tldr
    unzip
    uv
  ];

  home.stateVersion = "22.11";

  home.sessionVariables = {
    EDITOR = "nvim";
    COLORTERM = "truecolor";
  };

  programs.bash.enable = true;

  programs.direnv = {
    enable = true;
    nix-direnv.enable = true;
  };

  programs.home-manager.enable = true;

}

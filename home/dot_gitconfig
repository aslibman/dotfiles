# Helpful reference:
# https://jvns.ca/blog/2024/02/16/popular-git-config-options/#pull-ff-only-or-pull-rebase-true

[credential]
    helper = wincred
[user]
    name = Alex Libman
    email = 5430928+aslibman@users.noreply.github.com
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

[init]
    defaultBranch = main

# Set core pager to delta
[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    line-numbers = true
    hyperlinks = true
    colorMoved = default
    syntax-theme = Dracula

[pager]
    log = "bat -n --style=changes"

# Set diff algorithm to histogram, which better handlers reordering better
# https://luppeng.wordpress.com/2020/10/10/when-to-use-each-of-the-git-diff-algorithms/
[diff]
    algorithm = histogram
    color = no

# zdiff3 includes context about previous code when resolving merge conflicts
# https://ductile.systems/zdiff3/
[merge]
    conflictstyle = zdiff3

# Does not have decorations or color due to clash with bat
# See https://github.com/sharkdp/bat/discussions/2329
[log]
    decorate = no

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

# Set core pager to bat
[core]
    pager = bat -n --style=changes

# Does not have decorations or color due to clash with bat
# See https://github.com/sharkdp/bat/discussions/2329
[log]
    decorate = no
[diff]
    color = never
